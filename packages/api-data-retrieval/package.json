{
  "name": "api-data-retrieval",
  "version": "1.0.0",
  "description": "Microservice for retrieving event datasets and statistics for the SENG3011 Team Tango project",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "src/server.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "jest",
    "tsc": "tsc --project tsconfig.json",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint-fix": "eslint --fix 'src/**/*.{ts,js}'",
    "start": "ts-node -T src/server.ts",
    "cleanup-sync-request": "pkill -f node_modules/sync-rpc/lib/worker.js > /dev/null 2>&1",
    "posttest": "npm run cleanup-sync-request || true",
    "ts-node-coverage": "nyc --reporter=text --reporter=lcov ts-node -T src/server.ts",
    "dev": "ts-node-dev -T src/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
